# AI SaaS Client Environment Variables (Example template)
# Copy this file to '.env.local' and set the variables before running locally.

# Base endpoint for Axios client integrations
NEXT_PUBLIC_API_URL=https://jsonplaceholder.typicode.com

# Display brand identity name for headers/navbars
NEXT_PUBLIC_APP_NAME="AI SaaS Starter"

# Current project workspace configuration (development, staging, production)
NEXT_PUBLIC_ENV=development

# Gemini generative model integration API credential key (restricted environment access)
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
